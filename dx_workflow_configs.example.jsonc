          "lora_5": { "name": "", "strength": 1.0, "enabled": true }, // LoRA slot 5
          "lora_6": { "name": "", "strength": 1.0, "enabled": true }, // LoRA slot 6
          "lora_7": { "name": "", "strength": 1.0, "enabled": true }, // NOT USED by LTX node
          "lora_8": { "name": "", "strength": 1.0, "enabled": true }  // NOT USED by LTX node
        },
        "filename": { "file": "" },        // output filename (without extension)
        "flags": {
          "flag_1": { "label": "flag 1", "value": false }, // custom boolean toggle 1; label is the display name
          "flag_2": { "label": "flag 2", "value": false },  // custom boolean toggle 2
          "flag_3": { "label": "flag 3", "value": false }  // custom boolean toggle 3
        },
        "custom": {
